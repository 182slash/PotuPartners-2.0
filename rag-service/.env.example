# ─────────────────────────────────────────────────────────────────────────────
# PotuPartners RAG Service — Environment Variables
# Copy to .env and fill in all values
# ─────────────────────────────────────────────────────────────────────────────

# ─── Service Auth ─────────────────────────────────────────────────────────────
# Must match RAG_SERVICE_SECRET in the backend .env
RAG_SERVICE_SECRET=replace_with_same_32_character_hex_as_backend

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# Model for chat completion (gpt-4o is recommended for legal Q&A accuracy)
LLM_MODEL=gpt-4o

# Model for embeddings (text-embedding-3-small is cost-effective and high quality)
EMBEDDING_MODEL=text-embedding-3-small

# ─── LLM Behaviour ────────────────────────────────────────────────────────────
MAX_RETRIEVED_CHUNKS=5
TEMPERATURE=0.1
MAX_TOKENS=1000

# ─── ChromaDB (Vector Store) ──────────────────────────────────────────────────
CHROMA_PERSIST_PATH=./chroma_db
CHROMA_COLLECTION_NAME=potupartners_docs

# ─── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# ─── DigitalOcean Spaces (for downloading RAG source documents) ───────────────
DO_SPACES_KEY=your_spaces_access_key_id
DO_SPACES_SECRET=your_spaces_secret_access_key
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_BUCKET=potupartners-files

# ─── Backend Callback ─────────────────────────────────────────────────────────
# URL of the Node.js backend (used to notify when indexing is complete)
BACKEND_URL=http://127.0.0.1:4000
BACKEND_SERVICE_SECRET=replace_with_same_32_character_hex_as_backend

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
