# ─── PotuPartners Backend — local development .env ───────────────────────────
# Copy this file to .env and fill in the values.
# In production these are set as environment variables in the DO App Platform
# dashboard (never commit real secrets).

# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# PostgreSQL
# For local dev: run `docker compose up db` and use the connection string below.
# On DO App Platform this is auto-injected from the dev database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/potupartners

# JWT — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_at_least_32_chars_long_aaa
JWT_REFRESH_SECRET=change_me_at_least_32_chars_long_bbb
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Local file storage (volume mount path in production)
# On DO App Platform this maps to the volume at /workspace/uploads.
# Locally, any writable directory works.
UPLOAD_DIR=./uploads

# RAG service
RAG_SERVICE_URL=http://localhost:8000
RAG_SERVICE_SECRET=change_me_at_least_16_chars

# Logging
LOG_LEVEL=debug

# BCrypt
BCRYPT_ROUNDS=10
