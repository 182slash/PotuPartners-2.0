{
  "name": "potupartners-backend",
  "version": "1.0.0",
  "private": true,
  "description": "PotuPartners REST API + WebSocket server",
  "main": "dist/index.js",
  "scripts": {
    "dev":     "ts-node-dev --respawn --transpile-only src/index.ts",
    "build":   "tsc --project tsconfig.json",
    "start":   "node dist/index.js",
    "migrate": "node dist/db/migrate.js",
    "seed":    "ts-node src/scripts/seed.ts",
    "lint":    "eslint src --ext .ts"
  },
  "dependencies": {
    "express":            "4.19.2",
    "socket.io":          "4.7.5",
    "pg":                 "8.11.5",
    "bcryptjs":           "2.4.3",
    "jsonwebtoken":       "9.0.2",
    "multer":             "1.4.5-lts.1",
    "axios":              "1.7.2",
    "helmet":             "7.1.0",
    "cors":               "2.8.5",
    "express-rate-limit": "7.3.1",
    "zod":                "3.23.8",
    "file-type":          "19.0.0",
    "winston":            "3.13.0",
    "morgan":             "1.10.0",
    "uuid":               "10.0.0",
    "dotenv":             "16.4.5",
    "compression":        "1.7.4",
    "cookie-parser":      "1.4.6"
  },
  "devDependencies": {
    "typescript":           "5.4.5",
    "@types/express":       "4.17.21",
    "@types/node":          "20.12.12",
    "@types/pg":            "8.11.6",
    "@types/bcryptjs":      "2.4.6",
    "@types/jsonwebtoken":  "9.0.6",
    "@types/multer":        "1.4.11",
    "@types/cors":          "2.8.17",
    "@types/morgan":        "1.9.9",
    "@types/uuid":          "10.0.0",
    "@types/compression":   "1.7.5",
    "@types/cookie-parser": "1.4.7",
    "ts-node-dev":          "2.0.0",
    "eslint":               "8.57.0",
    "@typescript-eslint/eslint-plugin": "7.11.0",
    "@typescript-eslint/parser":        "7.11.0"
  }
}
